# =============================================================================
# L&Lui Logistique — Variables d'environnement backend
# Copier vers .env et remplir les valeurs
# =============================================================================

# ---- Serveur ----
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Base de données PostgreSQL + PostGIS ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=llui_transport
DB_USER=llui
DB_PASSWORD=CHANGE_ME
DB_SSL=false
DB_POOL_MAX=20

# ---- Redis (BullMQ + cache) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING_IN_PRODUCTION

# ---- OCR : Mindee API ----
# Obtenir une clé sur https://platform.mindee.com
MINDEE_API_KEY=

# ---- Stockage fichiers ----
# Option A : AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=llui-transport-documents

# Option B : Firebase Storage (commenter si S3 utilisé)
FIREBASE_STORAGE_BUCKET=llui-transport.appspot.com
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ---- Notifications ----
# Firebase Cloud Messaging
FIREBASE_FCM_SERVER_KEY=

# Twilio (SMS fallback + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX  # Numéro Twilio source

# ---- Métier ----
# Marge opérateur sur les estimations de coût (%)
OPERATOR_MARGIN_PCT=12

# Taux d'assurance cargo (% de la valeur déclarée)
INSURANCE_RATE_PCT=0.8

# Seuil de distance pour check-in automatique (km)
AUTO_CHECKIN_DISTANCE_KM=190

# Alerte véhicule silencieux (heures sans signal GPS)
SILENT_VEHICLE_THRESHOLD_HOURS=4

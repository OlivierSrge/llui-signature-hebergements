rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Événements Kribi ─────────────────────────────────────────
    // Photos et PDFs programmes — lecture publique (page /kribi accessible sans login)
    match /evenements_kribi/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Hébergements ─────────────────────────────────────────────
    // Photos des hébergements — lecture publique
    match /hebergements/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Documents (notices, contrats) ────────────────────────────
    // Lecture authentifiée uniquement
    match /documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Prestataires ─────────────────────────────────────────────
    // Photos prestataires — lecture publique
    match /prestataires/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Photos mariages (upload portail) ─────────────────────────
    // Lecture publique pour affichage hero/topbar sans auth
    match /mariages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Tout le reste ────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

# ─────────────────────────────────────────────────────────
# L&Lui Signature Hébergements — variables d'environnement
# Copier dans .env.local pour le développement local
# ─────────────────────────────────────────────────────────

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Next.js public
NEXT_PUBLIC_APP_URL=https://llui-signature-hebergements.vercel.app
NEXT_PUBLIC_BOUTIQUE_URL=

# Google Maps — Carte partenaires + Picker admin
# APIs requises : Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_WHATSAPP_PHONE=693407964

# Google Sheets — Boutique
GOOGLE_SHEETS_BOUTIQUE_ID=

# Canal 2 — Google Sheets Prescripteurs Partenaires
# Sheet ID visible dans l'URL du Sheet : /spreadsheets/d/[ID]/edit
# Le service account (GOOGLE_CLIENT_EMAIL) doit être éditeur du Sheet
GOOGLE_SHEETS_CANAL2_ID=15tgAgMOSpzytCyh4YM_1CXXufhM93vBD6GjTDP8jfl4
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Canal 2 — Webhook Apps Script → Firebase
# Doit correspondre exactement au secret configuré dans Apps Script
# Header envoyé : Authorization: Bearer [SHEETS_WEBHOOK_SECRET]
SHEETS_WEBHOOK_SECRET=

# Cron jobs (Vercel)
CRON_SECRET=

# Auth admin
ADMIN_SECRET=

# Resend (emails)
RESEND_API_KEY=

# FCM (push notifications)
NEXT_PUBLIC_FCM_VAPID_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
